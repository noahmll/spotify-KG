# Vorlage für die .env-Datei. Kopieren nach ".env" und Werte eintragen.
# Die echte .env wird NICHT eingecheckt (siehe .gitignore).

# Spotify Web API — aus https://developer.spotify.com/dashboard (App → Settings)
SPOTIFY_CLIENT_ID=deine_spotify_client_id
SPOTIFY_CLIENT_SECRET=dein_spotify_client_secret

# Passwort der lokalen Neo4j-Instanz (beim Anlegen in Neo4j Desktop gesetzt)
NEO4J_PASSWORD=dein_neo4j_passwort
